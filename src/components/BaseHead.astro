---
interface Props {
  title: string;
  description: string;
  descriptionEn?: string;
  ogImage?: string;
  lang?: 'ja' | 'en';
}

const { title, description, descriptionEn, ogImage, lang = 'ja' } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site)
  : new URL(`${base}images/favicon-og.svg`, Astro.site);

const jaUrl = new URL(Astro.url.pathname.replace('/en/', '/').replace(/\/en$/, '/'), Astro.site);
const enUrl = new URL(Astro.url.pathname.includes('/en/') ? Astro.url.pathname : Astro.url.pathname.replace('/weson-museum/', '/weson-museum/en/'), Astro.site);
const ogLocale = lang === 'en' ? 'en_US' : 'ja_JP';

// JSON-LD: Organization + VirtualLocation schema (English for international indexing)
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://TIshow.github.io/weson-museum/#organization',
      name: 'WESON MUSEUM',
      url: 'https://TIshow.github.io/weson-museum/',
      sameAs: [
        'https://x.com/WESON_MUSEUM',
        'https://www.instagram.com/weson_museum/',
        'https://weson-museum.booth.pm/',
      ],
      description:
        'WESON MUSEUM is a virtual reality art museum on VRChat, offering permanent exhibitions and the annual ARTLINK group show. Open to visitors worldwide regardless of location.',
    },
    {
      '@type': 'Museum',
      '@id': 'https://TIshow.github.io/weson-museum/#museum',
      name: 'WESON MUSEUM',
      alternateName: ['ウェソンミュージアム', 'VR美術館'],
      url: 'https://TIshow.github.io/weson-museum/',
      description:
        'A virtual reality art museum built in VRChat. Featuring four permanent galleries — Sky, Palau, Forest, and Rain — plus the annual ARTLINK exhibition connecting artists and audiences across borders.',
      keywords: [
        'VR art museum', 'virtual reality museum', 'VRChat museum',
        'ARTLINK', 'metaverse art', 'Japanese contemporary art',
        'Palau art', 'VR gallery', 'online art exhibition',
        'VR美術館', 'バーチャル美術館', 'メタバース美術展',
      ],
      event: {
        '@type': 'Event',
        name: 'VR Gallery Tour',
        description: 'Weekly guided tour of WESON MUSEUM galleries. Every Saturday 21:00–22:00 JST on VRChat. Free entry, open to all.',
        eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
        location: {
          '@type': 'VirtualLocation',
          url: 'https://vrchat.com',
        },
        organizer: {
          '@id': 'https://TIshow.github.io/weson-museum/#organization',
        },
        schedule: {
          '@type': 'Schedule',
          repeatFrequency: 'P1W',
          byDay: 'https://schema.org/Saturday',
          startTime: '21:00',
          endTime: '22:00',
        },
      },
    },
  ],
};
---

<!-- charset & viewport -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang: ja/en bilingual routing -->
<link rel="alternate" hreflang="ja" href={jaUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={jaUrl} />

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
{descriptionEn && <meta name="description" lang="en" content={descriptionEn} />}

<!-- テーマカラー -->
<meta name="theme-color" content="#050b0a" />

<!-- Open Graph (Japanese) -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:site_name" content="WESON MUSEUM" />
<meta property="og:locale" content={ogLocale} />
{lang === 'ja' && <meta property="og:locale:alternate" content="en_US" />}
{lang === 'en' && <meta property="og:locale:alternate" content="ja_JP" />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@WESON_MUSEUM" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={descriptionEn ?? description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
<link rel="apple-touch-icon" href={`${base}favicon.svg`} />

<!-- Sitemap -->
<link rel="sitemap" href="/weson-museum/sitemap-index.xml" />

<!-- JSON-LD structured data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
