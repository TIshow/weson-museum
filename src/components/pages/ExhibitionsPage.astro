---
import BaseLayout from '@layouts/BaseLayout.astro';
import museumsData from '../../data/museums.json';

interface Props { lang: 'ja' | 'en' }
const { lang } = Astro.props;
const isEn = lang === 'en';
const p = isEn ? '/en' : '';

const base = import.meta.env.BASE_URL;
const museums = museumsData;

const t = {
  title: isEn
    ? 'Permanent Exhibitions — WESON MUSEUM | VRChat VR Museum'
    : '常設展示 — WESON MUSEUM | VRChat VR美術館',
  description: isEn
    ? 'WESON MUSEUM\'s permanent exhibitions on VRChat: four unique galleries — Sky, Palau, Forest, and Rain — each with its own atmosphere and VR-exclusive presentation.'
    : 'WESON MUSEUMの常設展示。VRChat上に開かれた4つの美術館——天空・パラオ・森・雨降る——それぞれが固有の空気と演出を持つ空間です。',
  descriptionEn: isEn ? undefined
    : 'WESON MUSEUM\'s permanent exhibitions on VRChat: four unique galleries — Sky, Palau, Forest, and Rain — each with its own atmosphere and VR-exclusive presentation. The Palau Museum is operated under the patronage of the Embassy of the Republic of Palau.',
  breadcrumbLabel: isEn ? 'Breadcrumb' : 'パンくずリスト',
  homeHref: isEn ? '/en/' : '/',
  lead: isEn
    ? 'WESON MUSEUM has four permanent galleries on VRChat. Each space has its own atmosphere and presentation, with continuous exhibitions.'
    : 'WESON MUSEUM は、VRChat 上に4つの常設美術館を持ちます。それぞれ異なる空気と演出を持つ空間で、作品の展示が継続的に行われています。',
  tourNote: isEn
    ? 'VR Gallery Tour — Every Saturday 21:00–22:00 / Rotating across galleries on VRChat'
    : 'VR在廊ツアー — 毎週土曜日 21:00〜22:00 ／ VRChat上の各館を巡回開催',
  enterBtn: isEn ? 'Enter on VRChat' : 'VRChatで入場する',
  renovationAriaLabel: isEn ? 'Renovation planned' : 'リニューアル予定',
  ctaAriaLabel: isEn ? 'Related pages' : '関連ページへの導線',
  ctaNavLabel: isEn ? 'Links to related pages' : '関連ページへのリンク',
  artlinkSub: isEn ? 'View special exhibitions' : '企画展を見る',
  aboutSub:   isEn ? 'About the museum' : '美術館について',
  newsSub:    isEn ? 'Latest updates' : '最新情報',
};
---

<BaseLayout
  title={t.title}
  description={t.description}
  descriptionEn={t.descriptionEn}
  lang={isEn ? 'en' : undefined}
>

  <!-- Hero -->
  <section class="ex-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label={t.breadcrumbLabel}>
        <ol>
          <li><a href={t.homeHref}>Home</a></li>
          <li aria-current="page">Exhibitions</li>
        </ol>
      </nav>

      <p class="ex-eyebrow mono-label">Permanent Exhibitions — VRChat</p>
      <h1 class="ex-h1">Exhibitions</h1>
      <p class="ex-lead">
        {isEn ? (
          <>WESON MUSEUM has four permanent galleries on VRChat.<br class="br-md" />Each space has its own atmosphere and presentation, with continuous exhibitions.</>
        ) : (
          <>WESON MUSEUM は、VRChat 上に4つの常設美術館を持ちます。<br class="br-md" />それぞれ異なる空気と演出を持つ空間で、作品の展示が継続的に行われています。</>
        )}
      </p>

      <div class="tour-note glass">
        <span class="status-dot" aria-hidden="true"></span>
        <p class="mono-label">{t.tourNote}</p>
      </div>
    </div>
  </section>

  <!-- Museums -->
  <div class="museums">
    {museums.map((m, i) => (
      <section
        id={`museum-${m.num}`}
        class={`museum-section${i % 2 === 1 ? ' museum-section--alt' : ''}`}
        aria-labelledby={`museum-heading-${m.num}`}
      >
        <div class="container museum-layout">

          <div class="museum-img-col">
            <div class="museum-img-wrap">
              <img
                src={`${base}images/museums/${m.img}`}
                alt={isEn ? m.en : m.ja}
                loading="lazy"
                decoding="async"
                class={m.status === 'renovation' ? 'img-renovation' : ''}
              />
              {m.status === 'renovation' && (
                <div class="closed-badge mono-label" aria-label={t.renovationAriaLabel}>
                  Renovation Planned
                </div>
              )}
            </div>
          </div>

          <div class="museum-text-col">
            <div class="museum-num mono-label">{m.num}</div>
            <span class="accent-line"></span>
            <h2 id={`museum-heading-${m.num}`} class="museum-primary">
              {isEn ? m.en : m.ja}
            </h2>
            <p class="museum-secondary mono-label">
              {isEn ? m.ja : m.en}{m.since && ` — Est. ${m.since}`}
            </p>
            <p class="museum-body">{isEn ? m.bodyEn : m.bodyJa}</p>
            {m.bodyPau && (
              isEn ? (
                <p class="museum-body-supplement" lang="pau">{m.bodyPau}</p>
              ) : (
                <p class="museum-body-supplement" lang="en">{m.bodyEn}</p>
              )
            )}

            <a
              href={m.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline museum-btn"
            >
              {t.enterBtn}
              <span class="btn-icon" aria-hidden="true">↗</span>
            </a>
          </div>

        </div>
      </section>
    ))}
  </div>

  <!-- CTA -->
  <section class="ex-cta" aria-label={t.ctaAriaLabel}>
    <div class="container">
      <div class="cta-divider" aria-hidden="true"></div>
      <p class="cta-lead mono-label">Explore WESON MUSEUM</p>
      <nav aria-label={t.ctaNavLabel}>
        <ul class="cta-links">
          <li>
            <a href={`${p}/artlink/`} class="btn btn-outline">
              ARTLINK
              <span class="cta-link-sub">{t.artlinkSub}</span>
            </a>
          </li>
          <li>
            <a href={`${p}/about/`} class="btn btn-outline">
              About
              <span class="cta-link-sub">{t.aboutSub}</span>
            </a>
          </li>
          <li>
            <a href={`${p}/news/`} class="btn btn-outline">
              News
              <span class="cta-link-sub">{t.newsSub}</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </section>

</BaseLayout>

<style>
  .ex-hero {
    padding-block: var(--space-16) var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .ex-eyebrow {
    color: var(--color-main);
    margin-bottom: var(--space-4);
  }

  .ex-h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
    font-weight: 200;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-6);
  }

  .ex-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 2;
    max-width: var(--content-width);
    margin-bottom: var(--space-8);
  }

  .br-md { display: none; }
  @media (min-width: 640px) { .br-md { display: block; } }

  .tour-note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
  }

  .tour-note .mono-label {
    color: var(--color-main);
    letter-spacing: var(--tracking-wide);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-main);
    box-shadow: var(--glow-main);
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .museum-section {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .museum-section--alt {
    background: var(--color-bg-1);
  }

  .museum-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .museum-section--alt .museum-img-col { order: 2; }
  .museum-section--alt .museum-text-col { order: 1; }

  @media (max-width: 768px) {
    .museum-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .museum-section--alt .museum-img-col,
    .museum-section--alt .museum-text-col { order: unset; }
    .museum-section { padding-block: var(--space-12); }
  }

  .museum-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .museum-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.8) saturate(0.9);
    transition: transform var(--transition-slow), filter var(--transition-slow);
  }

  .museum-img-wrap:hover img {
    transform: scale(1.03);
    filter: brightness(0.9) saturate(1.05);
  }

  .img-renovation {
    filter: brightness(0.7) saturate(0.6) !important;
  }

  .closed-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(5, 11, 10, 0.85);
    border: 1px solid var(--color-border-bright);
    color: var(--color-text-muted);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    letter-spacing: var(--tracking-widest);
  }

  .museum-text-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .museum-num {
    color: var(--color-main);
  }

  .museum-primary {
    font-size: var(--text-2xl);
    font-weight: 200;
    letter-spacing: var(--tracking-wider);
    line-height: 1.2;
  }

  .museum-secondary {
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-widest);
    margin-top: calc(-1 * var(--space-2));
  }

  .museum-body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 2;
    margin-top: var(--space-2);
  }

  .museum-body-supplement {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    line-height: 1.9;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin-top: var(--space-2);
  }

  .museum-btn {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  .btn-icon {
    font-size: var(--text-sm);
    color: var(--color-main);
  }

  .ex-cta {
    padding-block: var(--space-24);
  }

  @media (max-width: 640px) {
    .ex-cta { padding-block: var(--space-16); }
  }

  .btn {
    display: inline-flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cta-link-sub {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-normal);
    text-transform: none;
    color: var(--color-text-muted);
  }
</style>
