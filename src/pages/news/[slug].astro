---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const pubDate = post.data.pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const updatedDate = post.data.updatedDate
  ? post.data.updatedDate.toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout
  title={`${post.data.title} — WESON MUSEUM`}
  description={post.data.description}
>
  <article class="container article-wrap">

    <nav class="breadcrumb" aria-label="パンくずリスト">
      <ol>
        <li><a href="/weson-museum/">Home</a></li>
        <li><a href="/weson-museum/news/">News</a></li>
        <li aria-current="page">{post.data.title}</li>
      </ol>
    </nav>

    <header class="article-header">
      <div class="article-meta">
        <time class="mono-label article-date" datetime={post.data.pubDate.toISOString()}>
          {pubDate}
        </time>
        {updatedDate && (
          <span class="mono-label article-updated">更新: {updatedDate}</span>
        )}
        <div class="article-tags">
          {post.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>

      <span class="accent-line"></span>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-desc">{post.data.description}</p>
    </header>

    <div class="article-body prose">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/weson-museum/news/" class="btn btn-outline">← News 一覧へ</a>
    </footer>

  </article>
</BaseLayout>

<style>
  .article-wrap {
    padding-block: var(--space-12) var(--space-24);
    max-width: 860px;
  }

  /* ---- Breadcrumb ---- */
  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-12);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-2);
    color: var(--color-border-bright);
  }

  .breadcrumb a {
    color: var(--color-text-subtle);
  }

  .breadcrumb a:hover {
    color: var(--color-main);
  }

  /* ---- Header ---- */
  .article-header {
    margin-bottom: var(--space-12);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .article-date {
    color: var(--color-text-subtle);
  }

  .article-updated {
    color: var(--color-text-subtle);
  }

  .article-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .accent-line {
    margin-bottom: var(--space-6);
  }

  .article-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    line-height: 1.4;
    margin-bottom: var(--space-6);
  }

  .article-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.9;
    border-left: 2px solid var(--color-border-bright);
    padding-left: var(--space-6);
  }

  /* ---- Body ---- */
  .prose {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-12);
  }

  .prose :global(p) {
    line-height: 2;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .prose :global(h2) {
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-12);
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .prose :global(li) {
    color: var(--color-text-muted);
    line-height: 1.9;
  }

  .prose :global(a) {
    color: var(--color-main);
    border-bottom: 1px solid var(--color-border-bright);
    padding-bottom: 1px;
  }

  .prose :global(a:hover) {
    color: var(--color-main-light);
    border-color: var(--color-main);
    text-decoration: none;
  }

  /* ---- Footer ---- */
  .article-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .article-wrap {
      padding-block: var(--space-8) var(--space-16);
    }
  }
</style>
