---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news', ({ data }) => !data.draft);

const sorted = allNews.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="News — WESON MUSEUM"
  description="WESON MUSEUMのお知らせ・活動報告・展示情報などをお届けします。"
>
  <div class="container page-wrap">

    <header class="page-header">
      <span class="accent-line"></span>
      <div>
        <p class="page-label mono-label">News &amp; Reports</p>
        <h1>News</h1>
        <p class="page-count mono-label">{sorted.length} 件</p>
      </div>
    </header>

    <ol class="news-list" reversed>
      {sorted.map((post, i) => {
        const date = post.data.pubDate.toLocaleDateString('ja-JP', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <li class="news-row">
            <span class="news-num mono-label">{String(sorted.length - i).padStart(2, '0')}</span>
            <div class="news-body">
              <div class="news-meta">
                <time class="news-date mono-label" datetime={post.data.pubDate.toISOString()}>
                  {date}
                </time>
                {post.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <a href={`/news/${post.slug}/`} class="news-title">
                {post.data.title}
              </a>
              <p class="news-desc">{post.data.description}</p>
            </div>
          </li>
        );
      })}
    </ol>

    <div class="back-link">
      <a href="/" class="btn btn-outline">← トップへ戻る</a>
    </div>

  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding-block: var(--space-16) var(--space-24);
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  .page-label {
    color: var(--color-main);
    margin-bottom: var(--space-2);
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: 200;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-2);
  }

  .page-count {
    color: var(--color-text-subtle);
  }

  /* ---- リスト ---- */
  .news-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .news-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-6);
    align-items: start;
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition-fast);
  }

  .news-row:hover {
    background: var(--color-bg-glass);
  }

  .news-num {
    color: var(--color-text-subtle);
    padding-top: 2px;
    text-align: right;
  }

  .news-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .news-date {
    color: var(--color-text-subtle);
  }

  .news-title {
    font-size: var(--text-lg);
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    line-height: 1.5;
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .news-title:hover {
    color: var(--color-main-light);
    text-decoration: none;
  }

  .news-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  @media (max-width: 640px) {
    .page-wrap {
      padding-block: var(--space-12) var(--space-16);
    }

    h1 {
      font-size: var(--text-2xl);
    }

    .news-title {
      font-size: var(--text-base);
    }
  }

  .back-link {
    margin-top: var(--space-16);
  }
</style>
