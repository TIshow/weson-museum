---
import BaseLayout from '@layouts/BaseLayout.astro';
import Gallery from '@components/Gallery.astro';
---

<BaseLayout title="WESON MUSEUM — VRで体験する現代アートの美術館">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <p class="hero-eyebrow mono-label">Virtual Reality Art Museum</p>
      <h1 class="hero-title">
        <span class="hero-title-w">W</span>ESON<br />
        <span class="hero-title-sub">MUSEUM</span>
      </h1>
      <p class="hero-description">
        バーチャルリアリティで体験する、新しい次元のアート空間。
      </p>
      <div class="hero-actions">
        <a href="/weson-museum/exhibitions/" class="btn btn-primary">Enter Exhibition</a>
        <a href="/weson-museum/about/" class="btn btn-outline">About Museum</a>
      </div>
    </div>
  </section>

  <!-- 3D Gallery -->
  <section class="section-gallery" aria-label="作品ギャラリー">
    <Gallery />
    <div class="gallery-label container" aria-hidden="true">
      <span class="mono-label">// Collection</span>
    </div>
  </section>

  <!-- Museum Info -->
  <section class="section-info">
    <div class="container info-grid">

      <!-- 常設展 -->
      <div class="info-block">
        <span class="accent-line"></span>
        <h2>Permanent Exhibitions</h2>
        <ul class="museum-list">
          <li>
            <span class="museum-num mono-label">01</span>
            <span class="museum-name">天空美術館</span>
          </li>
          <li>
            <span class="museum-num mono-label">02</span>
            <span class="museum-name">森美術館</span>
          </li>
          <li>
            <span class="museum-num mono-label">03</span>
            <span class="museum-name">パラオ美術館</span>
          </li>
          <li>
            <span class="museum-num mono-label">04</span>
            <span class="museum-name">雨降る美術館</span>
          </li>
        </ul>
        <a href="/weson-museum/exhibitions/" class="btn btn-outline" style="margin-top: var(--space-8)">
          View All
        </a>
      </div>

      <!-- 在廊ツアー -->
      <div class="info-block">
        <span class="accent-line" style="background: var(--color-accent); box-shadow: 0 0 12px var(--color-accent);"></span>
        <h2>VR Gallery Tour</h2>
        <div class="tour-card glass">
          <div class="tour-time">
            <span class="mono-label">Every Saturday</span>
            <span class="tour-hour">21:00 — 22:00</span>
          </div>
          <p class="tour-desc">
            VRChat 上の展示空間をアーティストと一緒に巡るガイドツアー。
            作品の制作背景や意図を直接聞けます。
          </p>
          <div class="tour-meta mono-label">
            <span>
              <span class="status-dot" aria-hidden="true"></span>
              VRChat
            </span>
            <span>Free</span>
          </div>
        </div>
      </div>

      <!-- ARTLINK -->
      <div class="info-block">
        <span class="accent-line"></span>
        <h2>ARTLINK</h2>
        <p class="artlink-desc">
          複数作家による VR 総合美術展。年に数回開催。<br />
          多様な表現が一つの仮想空間に集結します。
        </p>
        <a href="/weson-museum/artlink/" class="btn btn-outline" style="margin-top: var(--space-8)">
          Past Exhibitions
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    padding-block: var(--space-24) var(--space-16);
    text-align: center;
  }

  .hero-eyebrow {
    color: var(--color-main);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-size: var(--text-hero);
    font-weight: 200;
    letter-spacing: var(--tracking-widest);
    line-height: 0.9;
    margin-bottom: var(--space-8);
  }

  .hero-title-w {
    color: var(--color-accent);
    font-weight: 700;
    text-shadow: 0 0 40px rgba(252, 250, 10, 0.5), 0 0 80px rgba(252, 250, 10, 0.2);
  }

  .hero-title-sub {
    display: block;
    font-size: 0.52em;
    letter-spacing: 0.42em;
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-10);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ---- Gallery Section ---- */
  .section-gallery {
    margin-block: var(--space-8);
  }

  .gallery-label {
    padding-block: var(--space-4);
    color: var(--color-text-subtle);
  }

  /* ---- Info Grid ---- */
  .section-info {
    padding-block: var(--space-16) var(--space-24);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 900px) {
    .info-grid {
      grid-template-columns: 1fr;
      max-width: 540px;
    }
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .info-block h2 {
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: var(--tracking-wider);
  }

  /* --- Museum List --- */
  .museum-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .museum-list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .museum-num {
    color: var(--color-main);
    flex-shrink: 0;
  }

  .museum-name {
    font-size: var(--text-base);
    letter-spacing: var(--tracking-wide);
  }

  /* --- Tour Card --- */
  .tour-card {
    padding: var(--space-6);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tour-time {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .tour-hour {
    font-size: var(--text-2xl);
    font-weight: 200;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
    text-shadow: 0 0 20px rgba(252, 250, 10, 0.3);
  }

  .tour-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .tour-meta {
    display: flex;
    justify-content: space-between;
    color: var(--color-main);
  }

  .tour-meta span {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* --- ARTLINK --- */
  .artlink-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.9;
  }
</style>
