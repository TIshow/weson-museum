---
import BaseLayout from '@layouts/BaseLayout.astro';
import museumsData from '../../data/museums.json';

const base = import.meta.env.BASE_URL;
const museums = museumsData;
---

<BaseLayout
  title="Permanent Exhibitions — WESON MUSEUM | VRChat VR Museum"
  description="WESON MUSEUM's permanent exhibitions on VRChat: four unique galleries — Sky, Palau, Forest, and Rain — each with its own atmosphere and VR-exclusive presentation."
  lang="en"
>

  <!-- Hero -->
  <section class="ex-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/en/">Home</a></li>
          <li aria-current="page">Exhibitions</li>
        </ol>
      </nav>

      <p class="ex-eyebrow mono-label">Permanent Exhibitions — VRChat</p>
      <h1 class="ex-h1">Exhibitions</h1>
      <p class="ex-lead">
        WESON MUSEUM has four permanent galleries on VRChat.<br class="br-md" />
        Each space has its own atmosphere and presentation, with continuous exhibitions.
      </p>

      <div class="tour-note glass">
        <span class="status-dot" aria-hidden="true"></span>
        <p class="mono-label">
          VR Gallery Tour — Every Saturday 21:00–22:00 / Rotating across galleries on VRChat
        </p>
      </div>
    </div>
  </section>

  <!-- Museums -->
  <div class="museums">
    {museums.map((m, i) => (
      <section
        id={`museum-${m.num}`}
        class={`museum-section${i % 2 === 1 ? ' museum-section--alt' : ''}`}
        aria-labelledby={`museum-heading-${m.num}`}
      >
        <div class="container museum-layout">

          <div class="museum-img-col">
            <div class="museum-img-wrap">
              <img
                src={`${base}images/museums/${m.img}`}
                alt={m.en}
                loading="lazy"
                decoding="async"
                class={m.status === 'renovation' ? 'img-renovation' : ''}
              />
              {m.status === 'renovation' && (
                <div class="closed-badge mono-label" aria-label="Renovation planned">
                  Renovation Planned
                </div>
              )}
            </div>
          </div>

          <div class="museum-text-col">
            <div class="museum-num mono-label">{m.num}</div>
            <span class="accent-line"></span>
            <h2 id={`museum-heading-${m.num}`} class="museum-name">{m.en}</h2>
            <p class="museum-ja mono-label">{m.ja}{m.since && ` — Est. ${m.since}`}</p>
            <p class="museum-body">{m.bodyEn}</p>
            {m.bodyPau && (
              <p class="museum-body-extra" lang="pau">{m.bodyPau}</p>
            )}

            <a
              href={m.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline museum-btn"
            >
              Enter on VRChat
              <span class="btn-icon" aria-hidden="true">↗</span>
            </a>
          </div>

        </div>
      </section>
    ))}
  </div>

  <!-- CTA -->
  <section class="ex-cta" aria-label="Related pages">
    <div class="container">
      <div class="cta-divider" aria-hidden="true"></div>
      <p class="cta-lead mono-label">Explore WESON MUSEUM</p>
      <nav aria-label="Links to related pages">
        <ul class="cta-links">
          <li>
            <a href="/en/artlink/" class="btn btn-outline">
              ARTLINK
              <span class="cta-link-sub">View special exhibitions</span>
            </a>
          </li>
          <li>
            <a href="/en/about/" class="btn btn-outline">
              About
              <span class="cta-link-sub">About the museum</span>
            </a>
          </li>
          <li>
            <a href="/en/news/" class="btn btn-outline">
              News
              <span class="cta-link-sub">Latest updates</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </section>

</BaseLayout>

<style>
  .ex-hero {
    padding-block: var(--space-16) var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .ex-eyebrow {
    color: var(--color-main);
    margin-bottom: var(--space-4);
  }

  .ex-h1 {
    font-size: clamp(2.4rem, 7vw, 4rem);
    font-weight: 200;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-6);
  }

  .ex-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 2;
    max-width: var(--content-width);
    margin-bottom: var(--space-10);
  }

  .br-md { display: none; }
  @media (min-width: 640px) { .br-md { display: block; } }

  .tour-note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
  }

  .tour-note .mono-label {
    color: var(--color-main);
    letter-spacing: var(--tracking-wide);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-main);
    box-shadow: var(--glow-main);
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .museum-section {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .museum-section--alt {
    background: var(--color-bg-1);
  }

  .museum-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .museum-section--alt .museum-img-col { order: 2; }
  .museum-section--alt .museum-text-col { order: 1; }

  @media (max-width: 768px) {
    .museum-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .museum-section--alt .museum-img-col,
    .museum-section--alt .museum-text-col { order: unset; }
    .museum-section { padding-block: var(--space-12); }
  }

  .museum-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .museum-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.8) saturate(0.9);
    transition: transform var(--transition-slow), filter var(--transition-slow);
  }

  .museum-img-wrap:hover img {
    transform: scale(1.03);
    filter: brightness(0.9) saturate(1.05);
  }

  .img-renovation { filter: brightness(0.7) saturate(0.6) !important; }

  .closed-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(5,11,10,0.85);
    border: 1px solid var(--color-border-bright);
    color: var(--color-text-muted);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    letter-spacing: var(--tracking-widest);
  }

  .museum-text-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .museum-num { color: var(--color-main); }

  .museum-name {
    font-size: var(--text-2xl);
    font-weight: 200;
    letter-spacing: var(--tracking-wider);
    line-height: 1.2;
  }

  .museum-ja {
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-widest);
    margin-top: calc(-1 * var(--space-2));
  }

  .museum-body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 2;
    margin-top: var(--space-2);
  }

  .museum-body-extra {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    line-height: 1.9;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin-top: var(--space-2);
  }

  .museum-btn {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  .btn-icon {
    font-size: var(--text-sm);
    color: var(--color-main);
  }

  .ex-cta {
    padding-block: var(--space-24);
  }

  @media (max-width: 640px) {
    .ex-cta { padding-block: var(--space-16); }
  }

  .btn {
    display: inline-flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cta-link-sub {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-normal);
    text-transform: none;
    color: var(--color-text-muted);
  }
</style>
