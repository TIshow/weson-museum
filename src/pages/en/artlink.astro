---
import BaseLayout from '@layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const connections = [
  {
    num: '01',
    en: 'Art and those yet to encounter it',
    ja: '美術と、まだ出会っていない人',
    body: "People who don't usually go to museums, who don't know how to look at works — when they wander into a VR space and stop in front of a work, that chance encounter is something ARTLINK values.",
  },
  {
    num: '02',
    en: 'Works and dialogue',
    ja: '作品と、対話の時間',
    body: 'At the weekly Saturday tours, the artist joins the space in person and talks with visitors. Being able to hear directly about the work makes the experience of viewing deeper and more personal.',
  },
  {
    num: '03',
    en: 'Artists and new audiences',
    ja: '作家と、新しい鑑賞者',
    body: "Through the VR channel, artists encounter audiences they couldn't reach before. Even artists unfamiliar with technology have found, through continued exhibition, that fans emerge from unexpected places.",
  },
  {
    num: '04',
    en: 'Virtual encounters, real movements',
    ja: 'バーチャルでの出会いが、リアルを動かす',
    body: 'Viewers who first encountered an artist through VR have gone on to attend their physical exhibitions. A connection in virtual space can become a door to real-world action and ongoing relationships.',
  },
];

const archives = [
  { year: '2025', path: `${base}news/artlink-2025-report/`, note: 'Latest' },
  { year: '2024', path: `${base}news/artlink-2024-report/`, note: '' },
];
---

<BaseLayout
  title="ARTLINK Group VR Art Exhibition | WESON MUSEUM"
  description="ARTLINK is a group VR art exhibition hosted on WESON MUSEUM. Held several times a year on VRChat, it connects artists with new audiences and bridges virtual and real-world art experiences."
  lang="en"
>

  <!-- ================================================================
       Hero
       ================================================================ -->
  <section class="al-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/en/">Home</a></li>
          <li aria-current="page">ARTLINK</li>
        </ol>
      </nav>

      <p class="al-eyebrow mono-label">Special Exhibition — WESON MUSEUM</p>

      <h1 class="al-h1">ARTLINK</h1>

      <p class="al-subline">New connections between art and people, opened by VR</p>
      <p class="al-subline-en mono-label">Connecting art, people, and spaces</p>

      <p class="al-lead">
        ARTLINK is a group VR art exhibition hosted on WESON MUSEUM.
        Held several times a year, it aims to create new connections between art
        and those who have had little opportunity to encounter it.
      </p>
    </div>
  </section>

  <!-- ================================================================
       Image
       ================================================================ -->
  <div class="al-image-wrap">
    <img
      src={`${base}images/artlink2025.jpg`}
      alt="ARTLINK 2025 — WESON MUSEUM"
      loading="eager"
      decoding="async"
      class="al-image"
    />
    <div class="al-image-overlay" aria-hidden="true"></div>
  </div>

  <!-- ================================================================
       Section 1: About ARTLINK
       ================================================================ -->
  <section class="al-section" aria-labelledby="sec-what">
    <div class="container">
      <div class="section-layout">
        <div class="section-aside">
          <span class="accent-line"></span>
          <h2 id="sec-what" class="section-heading">
            About ARTLINK
          </h2>
        </div>
        <div class="section-body prose">
          <p>
            ARTLINK is not simply a venue for digital exhibition.
            Set in the VR spaces cultivated by WESON MUSEUM, it is a program where artists gather,
            display work, engage in dialogue, and share space with audiences.
          </p>
          <p>
            We do not think of "exhibiting" as merely hanging work on a wall.
            Artists and viewers stand in the same place, words emerge,
            and those words lead to the next relationship —
            ARTLINK continues as a program to cultivate exactly that kind of space.
          </p>
          <p>
            Lowering the threshold of viewing, widening access to art — these questions,
            approached through the technology of VR, form the basic stance of this exhibition.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       Section 2: There is value in the accidental encounter
       ================================================================ -->
  <section class="al-section al-section--tinted" aria-labelledby="sec-encounter">
    <div class="container">
      <div class="section-layout">
        <div class="section-aside">
          <span class="accent-line" style="background:var(--color-accent);box-shadow:0 0 12px var(--color-accent);"></span>
          <h2 id="sec-encounter" class="section-heading">
            There is value in<br />the accidental<br />encounter
          </h2>
        </div>
        <div class="section-body prose">
          <p>
            In Japan, art is sometimes received as a culture slightly removed from everyday life.
            "Museums feel intimidating." "I don't know how to look at works."
            These feelings are not uncommon.
          </p>
          <p>
            Entering a VR space requires no special preparation, no prior knowledge.
            Someone invited by a friend, or someone who wandered in —
            when they find themselves standing in front of a work by chance,
            that can become their first point of contact with art.
          </p>
          <p>
            Many people who attend the weekly Saturday tours are those who rarely visit art museums,
            or who don't know how to talk about works.
            Even so, what they feel in front of a work, and the words they exchange with an artist,
            remain as something real.
          </p>
          <p>
            Lowering the threshold of access is not about making art "easier".
            It is about widening the door, so that more people have the opportunity
            to encounter the depth of art.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       Section 3: What ARTLINK connects
       ================================================================ -->
  <section class="al-section" aria-labelledby="sec-connects">
    <div class="container">
      <header class="center-header">
        <span class="accent-line" style="margin-inline: auto;"></span>
        <h2 id="sec-connects" class="center-heading">What ARTLINK connects</h2>
      </header>

      <ol class="connects-grid" aria-label="What ARTLINK connects">
        {connections.map(c => (
          <li class="connect-item">
            <span class="connect-num mono-label">{c.num}</span>
            <h3 class="connect-en">{c.en}</h3>
            <p class="connect-ja mono-label">{c.ja}</p>
            <p class="connect-body">{c.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ================================================================
       Section 4: Relationship with WESON MUSEUM
       ================================================================ -->
  <section class="al-section al-section--tinted" aria-labelledby="sec-relation">
    <div class="container">
      <div class="section-layout">
        <div class="section-aside">
          <span class="accent-line"></span>
          <h2 id="sec-relation" class="section-heading">
            Relationship with<br />WESON MUSEUM
          </h2>
        </div>
        <div class="section-body prose">
          <p>
            WESON MUSEUM is a permanent art museum built in VRChat.
            Four spaces — Sky, Forest, Palau, Rain — each with its own atmosphere,
            remain open at all times.
          </p>
          <p>
            ARTLINK is the "program" that makes use of that "place".
            Because WESON MUSEUM exists, ARTLINK can be held continuously.
            And because ARTLINK is held, WESON MUSEUM becomes known to more people,
            and the permanent exhibitions are seen with fresh eyes.
          </p>
          <p>
            A relationship in which place and program nurture each other —
            ARTLINK moves as one with WESON MUSEUM.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       Section 5: Widening the reach of art
       ================================================================ -->
  <section class="al-section" aria-labelledby="sec-goal">
    <div class="container">
      <div class="section-layout">
        <div class="section-aside">
          <span class="accent-line"></span>
          <h2 id="sec-goal" class="section-heading">
            Widening the<br />reach of art
          </h2>
        </div>
        <div class="section-body prose">
          <p>
            One of the goals of ARTLINK is to widen the reach of art.
          </p>
          <p>
            To create connections between those who have rarely had the opportunity to encounter art,
            and artists who want more people to see their work.
            To create points of contact between people and places that have seldom intersected.
            From those points of contact, new discoveries and relationships emerge — and we believe in that.
          </p>
          <p>
            VR is a means, not an end.
            What we want to hold onto does not change, even as technology changes —
            that art exists a little closer to the daily lives of more people.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       Section 6: Archive
       ================================================================ -->
  <section class="al-section al-section--tinted" aria-labelledby="sec-archive">
    <div class="container">
      <div class="section-layout">
        <div class="section-aside">
          <span class="accent-line"></span>
          <h2 id="sec-archive" class="section-heading">Archive</h2>
        </div>
        <div class="section-body">
          <p class="archive-intro">
            These are the exhibition records from past editions of ARTLINK.
            See the year-by-year pages for details.
          </p>
          <ul class="archive-list" aria-label="ARTLINK archive by year">
            {archives.map(a => (
              <li class="archive-row">
                <a href={a.path} class="archive-link">
                  <span class="archive-year mono-label">ARTLINK {a.year}</span>
                  {a.note && <span class="archive-note tag">{a.note}</span>}
                  <span class="archive-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
            <li class="archive-row">
              <a href="/en/news/" class="archive-link archive-link--all">
                <span class="archive-year mono-label">Full archive</span>
                <span class="archive-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       CTA
       ================================================================ -->
  <section class="al-cta" aria-label="Related pages">
    <div class="container">
      <div class="cta-divider" aria-hidden="true"></div>
      <p class="cta-lead mono-label">Explore WESON MUSEUM</p>
      <nav aria-label="Links to related pages">
        <ul class="cta-links">
          <li>
            <a href="/en/about/" class="btn btn-outline">
              About
              <span class="cta-link-sub">About the Museum</span>
            </a>
          </li>
          <li>
            <a href="/en/exhibitions/" class="btn btn-outline">
              Exhibitions
              <span class="cta-link-sub">View permanent exhibitions</span>
            </a>
          </li>
          <li>
            <a href="/en/media/" class="btn btn-outline">
              Press &amp; Media
              <span class="cta-link-sub">Press coverage</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </section>

</BaseLayout>

<style>
  .al-hero {
    padding-block: var(--space-16) var(--space-24);
    border-bottom: 1px solid var(--color-border);
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-12);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-2);
    color: var(--color-border-bright);
  }

  .breadcrumb a { color: var(--color-text-subtle); }
  .breadcrumb a:hover { color: var(--color-main); }

  .al-eyebrow {
    color: var(--color-main);
    margin-bottom: var(--space-6);
  }

  .al-h1 {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 200;
    letter-spacing: var(--tracking-widest);
    line-height: 1;
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .al-subline {
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .al-subline-en {
    color: var(--color-text-subtle);
    margin-bottom: var(--space-12);
  }

  .al-lead {
    font-size: var(--text-lg);
    line-height: 2;
    color: var(--color-text-muted);
    max-width: var(--content-width);
  }

  .br-md { display: none; }
  @media (min-width: 640px) { .br-md { display: block; } }

  @media (max-width: 640px) {
    .al-hero { padding-block: var(--space-12) var(--space-16); }
    .al-subline { font-size: var(--text-lg); }
    .al-lead { font-size: var(--text-base); }
  }

  .al-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 6;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .al-image-wrap { aspect-ratio: 16 / 9; }
  }

  .al-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.65) saturate(0.85);
    display: block;
  }

  .al-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, var(--color-bg) 0%, transparent 20%, transparent 80%, var(--color-bg) 100%);
    pointer-events: none;
  }

  .al-section {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--color-border);
  }

  .al-section--tinted { background: var(--color-bg-1); }

  @media (max-width: 640px) {
    .al-section { padding-block: var(--space-16); }
  }

  .section-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 768px) {
    .section-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .section-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: calc(var(--nav-height) + var(--space-8));
  }

  @media (max-width: 768px) {
    .section-aside {
      position: static;
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .section-heading {
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: var(--tracking-wider);
    line-height: 1.5;
  }

  .center-header {
    text-align: center;
    margin-bottom: var(--space-16);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .center-heading {
    font-size: var(--text-2xl);
    font-weight: 200;
    letter-spacing: var(--tracking-widest);
  }

  .prose p + p { margin-top: var(--space-6); }
  .prose p { line-height: 2; color: var(--color-text-muted); }

  .connects-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-1);
  }

  @media (max-width: 640px) {
    .connects-grid { grid-template-columns: 1fr; }
  }

  .connect-item {
    padding: var(--space-8);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .connect-item:hover {
    background: var(--color-bg-glass);
    border-color: var(--color-border-bright);
  }

  .connect-num { color: var(--color-main); }

  .connect-en {
    font-size: var(--text-lg);
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    line-height: 1.3;
  }

  .connect-ja {
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
  }

  .connect-body {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-top: var(--space-2);
  }

  .archive-intro {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 2;
    margin-bottom: var(--space-8);
  }

  .archive-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
    max-width: var(--content-width);
  }

  .archive-row { border-bottom: 1px solid var(--color-border); }

  .archive-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-5);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .archive-link:hover {
    color: var(--color-main);
    text-decoration: none;
  }

  .archive-link:hover .archive-arrow {
    transform: translateX(4px);
    color: var(--color-main);
  }

  .archive-year {
    color: inherit;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-widest);
  }

  .archive-note { font-size: var(--text-xs); }

  .archive-arrow {
    margin-left: auto;
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .archive-link--all .archive-year { color: var(--color-text-subtle); }

  .al-cta { padding-block: var(--space-24); }

  @media (max-width: 640px) {
    .al-cta { padding-block: var(--space-16); }
  }

  .cta-divider {
    width: 40px;
    height: 1px;
    background: var(--color-main);
    box-shadow: var(--glow-main);
    margin-bottom: var(--space-8);
  }

  .cta-lead {
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .cta-links {
    list-style: none;
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cta-link-sub {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-normal);
    text-transform: none;
    color: var(--color-text-muted);
  }
</style>
