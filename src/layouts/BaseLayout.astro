---
import BaseHead from '@components/BaseHead.astro';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
  descriptionEn?: string;
  ogImage?: string;
  lang?: 'ja' | 'en';
}

const {
  title,
  description = 'WESON MUSEUM — VRで体験する現代アートの美術館',
  descriptionEn,
  ogImage,
  lang = 'ja',
} = Astro.props;

const base = '/weson-museum';
const langBase = lang === 'en' ? `${base}/en` : base;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} descriptionEn={descriptionEn} ogImage={ogImage} lang={lang} />
  </head>
  <body>
    <header class="site-header">
      <nav class="container site-nav">
        <a href={`${langBase}/`} class="site-logo" aria-label="WESON MUSEUM ホームへ">
          <span class="logo-mark">W</span>
          <span class="logo-text">ESON MUSEUM</span>
        </a>

        <ul class="nav-links" role="list">
          <li><a href={`${langBase}/exhibitions/`}>Exhibitions</a></li>
          <li><a href={`${langBase}/news/`}>News</a></li>
          <li><a href={`${langBase}/about/`}>About</a></li>
          <li><LanguageSwitcher /></li>
        </ul>

        <!-- モバイル: ハンバーガーは将来実装 -->
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">

        <!-- ブランド + ソーシャル -->
        <div class="footer-brand">
          <span class="logo-text">WESON MUSEUM</span>
          <p class="footer-tagline mono-label">Virtual Reality Art Museum</p>

          <div class="footer-social" aria-label="SNS・外部リンク">
            <!-- X (Twitter) -->
            <a href="https://x.com/WESON_MUSEUM" target="_blank" rel="noopener noreferrer"
               class="social-link" aria-label="X (Twitter)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.402 6.231H2.744l7.728-8.835L1.254 2.25H8.08l4.261 5.635 5.903-5.635Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>

            <!-- Instagram -->
            <a href="https://www.instagram.com/weson_museum/" target="_blank" rel="noopener noreferrer"
               class="social-link" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </a>

            <!-- Discord -->
            <a href="https://discord.gg/kGHFcAZZDX" target="_blank" rel="noopener noreferrer"
               class="social-link" aria-label="Discord">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
              </svg>
            </a>

            <!-- BOOTH -->
            <a href="https://weson-museum.booth.pm/" target="_blank" rel="noopener noreferrer"
               class="social-link social-link--booth" aria-label="BOOTH 公式グッズ">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6 2a1 1 0 0 0-1 1v1H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1V3a1 1 0 1 0-2 0v1H7V3a1 1 0 0 0-1-1zm0 7a1 1 0 0 1 1-1h10a1 1 0 1 1 0 2H7a1 1 0 0 1-1-1z"/>
              </svg>
              <span class="mono-label">Official Goods</span>
            </a>
          </div>
        </div>

        <!-- サイト内ナビ -->
        <nav class="footer-nav" aria-label="フッターナビゲーション">
          <ul role="list">
            <li><a href={`${langBase}/exhibitions/`}>Exhibitions</a></li>
            <li><a href={`${langBase}/news/`}>News</a></li>
            <li><a href={`${langBase}/about/`}>About</a></li>
          </ul>
        </nav>
      </div>

      <div class="container footer-bottom">
        <span class="mono-label">&copy; {new Date().getFullYear()} WESON MUSEUM</span>
        <span class="mono-label footer-status">
          <span class="status-dot" aria-hidden="true"></span>
          System Online
        </span>
      </div>
    </footer>
  </body>
</html>

<style>
  /* ---- Header ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    background: rgba(5, 11, 10, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  /* ---- Logo ---- */
  .site-logo {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-base);
  }

  .site-logo:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .site-logo:hover .logo-mark {
    color: var(--color-accent);
    text-shadow: var(--glow-accent-strong);
  }

  .logo-mark {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0;
    margin-right: 0.1em;
    color: var(--color-main);
    text-shadow: var(--glow-main);
    transition: all var(--transition-base);
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  /* ---- Nav Links ---- */
  .nav-links {
    list-style: none;
    display: flex;
    gap: var(--space-8);
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding-block: var(--space-2);
    position: relative;
    transition: color var(--transition-base);
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-accent);
    box-shadow: var(--glow-accent);
    transform: scaleX(0);
    transition: transform var(--transition-base);
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-links a:hover::after {
    transform: scaleX(1);
  }

  .nav-lang {
    color: var(--color-main) !important;
    border: 1px solid var(--color-border-bright);
    padding: 2px var(--space-2) !important;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .nav-lang:hover {
    background: var(--color-bg-glass);
    border-color: var(--color-main) !important;
    box-shadow: var(--glow-main);
  }

  .nav-lang::after {
    display: none !important;
  }

  /* ---- Main ---- */
  #main-content {
    min-height: calc(100vh - var(--nav-height) - 160px);
  }

  /* ---- Footer ---- */
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-32);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-8);
    padding-block: var(--space-12);
  }

  .footer-tagline {
    margin-top: var(--space-2);
    color: var(--color-text-subtle);
  }

  /* ---- Social Links ---- */
  .footer-social {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .social-link:hover {
    color: var(--color-main);
    border-color: var(--color-border-bright);
    background: var(--color-bg-glass);
    box-shadow: var(--glow-main);
    text-decoration: none;
  }

  /* BOOTH は少し目立たせる */
  .social-link--booth {
    padding-inline: var(--space-3);
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }

  .social-link--booth:hover {
    color: var(--color-accent);
    border-color: var(--color-border-accent);
    box-shadow: var(--glow-accent);
  }

  .social-link--booth .mono-label {
    color: inherit;
    font-size: var(--text-xs);
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-end;
  }

  .footer-nav a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .footer-nav a:hover {
    color: var(--color-main);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-subtle);
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-main);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-main);
    box-shadow: var(--glow-main);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (max-width: 640px) {
    /* ---- Header mobile ---- */
    .logo-mark {
      font-size: 1.15rem;
    }

    .logo-text {
      font-size: 0.75rem;
      letter-spacing: var(--tracking-wide);
    }

    /* テキストナビを非表示、言語スイッチャーのみ残す */
    .nav-links li:not(:last-child) {
      display: none;
    }

    .nav-links {
      gap: var(--space-2);
    }

    .site-nav {
      gap: var(--space-4);
    }

    /* ---- Footer mobile ---- */
    .footer-inner {
      flex-direction: column;
    }

    .footer-nav ul {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
